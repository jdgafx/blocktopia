{
  "rules": {
    "players": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'x', 'y', 'z'])",
        "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "x": { ".validate": "newData.isNumber()" },
        "y": { ".validate": "newData.isNumber()" },
        "z": { ".validate": "newData.isNumber()" },
        "yaw": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "blocks": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && $key.matches(/^-?[0-9]+_[0-9]+_-?[0-9]+$/)"
      }
    }
  }
}
